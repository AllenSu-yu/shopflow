# ============================================
# ShopFlow 環境變數設定範例
# ============================================
# 複製此檔案為 .env 並填入實際值
# 開發環境：cp .env.example .env
# 生產環境：cp .env.example .env.production

# ============================================
# 環境設定
# ============================================
# 環境類型：development（開發）或 production（生產）
# 開發環境：使用 SQLite + 本地檔案
# 生產環境：使用 RDS PostgreSQL + S3
ENVIRONMENT=development

# ============================================
# 資料庫配置
# ============================================
# 開發環境：SQLite（自動使用預設路徑，無需設定）
# 生產環境：PostgreSQL（RDS）
# 格式：postgresql://username:password@host:port/database
# DATABASE_URL=postgresql://shopflow_admin:your_password@your-rds-endpoint.region.rds.amazonaws.com:5432/shopflow_db

# ============================================
# 應用程式配置
# ============================================
# 安全金鑰（用於 JWT 等加密操作）
# 生產環境請使用強隨機字串
SECRET_KEY=your-secret-key-here-change-in-production

# CORS 允許的來源網域（用逗號分隔）
# 開發環境預設允許本地開發網域
# 生產環境應設定實際的網域
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# 應用程式主機和端口
APP_HOST=0.0.0.0
APP_PORT=5000

# 是否啟用自動重載（開發環境建議 true，生產環境必須 false）
APP_RELOAD=true

# ============================================
# AWS S3 配置（僅生產環境需要）
# ============================================
# AWS 區域
AWS_REGION=ap-northeast-1

# AWS 存取金鑰（如果使用 IAM Role，可留空）
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 Bucket 名稱
# S3_BUCKET_NAME=shopflow-images

# S3 Base URL（選填，用於自訂 CloudFront CDN URL）
# 如果留空，將使用標準 S3 URL：https://bucket-name.s3.region.amazonaws.com
# S3_BASE_URL=https://cdn.yourdomain.com

# ============================================
# 檔案儲存模式
# ============================================
# local：本地檔案系統（開發環境）
# s3：AWS S3（生產環境）
# 預設：開發環境使用 local，生產環境使用 s3
FILE_STORAGE_MODE=local
